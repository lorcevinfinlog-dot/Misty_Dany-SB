})

MiscTab:CreateButton({
   Name = "🔴 Выгрузить скрипт (Unload)",
   Callback = function()
       -- 1. Отключаем все функции, чтобы персонаж не сломался
       if FlyToggle then FlyToggle:Set(false) end
       if PlatformToggle then PlatformToggle:Set(false) end
       if AntiRagdollToggle then AntiRagdollToggle:Set(false) end
       if AntiAfkToggle then AntiAfkToggle:Set(false) end
       
       -- 2. Возвращаем скорость и прыжок к стандарту
       if game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("Humanoid") then
           game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 16
           game.Players.LocalPlayer.Character.Humanoid.JumpPower = 50
       end
       
       -- 3. Полностью уничтожаем интерфейс Rayfield
       Rayfield:Destroy()
   end,
})
