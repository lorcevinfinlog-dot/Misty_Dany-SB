-- ПЛАТФОРМА НА -15 (Идеальная высота)
local PlatformToggle = PlayerTab:CreateToggle({
   Name = "Анти-Войд (Платформа -15)",
   CurrentValue = false,
   Callback = function(Value)
      platformEnabled = Value
      if platformEnabled then
          platform = Instance.new("Part", workspace)
          platform.Size = Vector3.new(2000, 1, 2000)
          platform.Anchored = true
          platform.Transparency = 0.7
          platform.Material = Enum.Material.ForceField
          
          task.spawn(function()
              while platformEnabled do
                  local char = game.Players.LocalPlayer.Character
                  if char and char:FindFirstChild("HumanoidRootPart") then
                      platform.Position = Vector3.new(char.HumanoidRootPart.Position.X, -15, char.HumanoidRootPart.Position.Z)
                  end
                  task.wait()
              end
              if platform then platform:Destroy() end
          end)
      elseif platform then
           platform:Destroy()
      end
   end,
})

-- Безопасность
local MiscTab = Window:CreateTab("Safety & Settings", 4483362458)

MiscTab:CreateButton({
   Name = "Анти чит (BETA)",
   Callback = function()
       local mt = getrawmetatable(game)
       local old = mt.__index
       setreadonly(mt, false)
       mt.__index = newcclosure(function(t, k)
           if not checkcaller() and t:IsA("Humanoid") and (k == "WalkSpeed" or k == "JumpPower") then
               return k == "WalkSpeed" and 16 or 50
           end
           return old(t, k)
       end)
       setreadonly(mt, true)
       Rayfield:Notify({Title = "Bypass", Content = "Анти-чит обманут", Duration = 3})
   end,
})

local AntiAfkToggle = MiscTab:CreateToggle({
   Name = "Анти-АФК(Anti-AFK)",
   CurrentValue = true,
   Callback = function(Value)
      antiAfkEnabled = Value
      if Value then
